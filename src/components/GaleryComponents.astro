---
import "../styles/global.css";

// 1. Ambil semua file .mp4 secara otomatis dari folder aset (Eager Load)
const allVideos = import.meta.glob("../assets/galery/*.mp4", { eager: true, import: "default" });

// 2. Petakan hasil glob menjadi array objek yang rapi
const videoPath = Object.entries(allVideos).map(([filePath, fileUrl]) => {
  const fileNameWithExt = filePath.split("/").pop() || "";
  const rawName = fileNameWithExt.replace(".mp4", ""); 

  const [name, date] = rawName.includes("_") 
    ? rawName.split("_") 
    : [rawName, "16-Mei-2026"]; 

  return {
    name: name.replace(/-/g, " "), 
    src: fileUrl as string,
    date: date
  };
});
---

<section aria-labelledby="gallery-title" class="py-16 bg-slate-50 min-h-screen">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Header Section Internal untuk Pengalaman Pengguna (UX) Yang Lebih Baik -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 id="gallery-title" class="text-3xl font-extrabold text-slate-900 tracking-tight sm:text-4xl">
        Dokumentasi Produksi Kami
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Intip proses manufaktur modern di balik pembuatan peralatan plastik dan alat kebersihan legendaris kami.
      </p>
    </div>

    <!-- Grid List Semantik -->
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 p-0 list-none">
      {
        videoPath.map((v) => (
          <li class="w-full flex bg-white flex-col justify-between rounded-2xl border border-slate-100 overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 group">
            <div class="w-full">
              <!-- Player Video dengan Aspek Rasio & Layout Shift Prevention -->
              <div class="aspect-video w-full bg-slate-950 relative overflow-hidden">
                <video 
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" 
                  controls 
                  preload="metadata"
                  muted
                  width="640"
                  height="360"
                >
                  <source src={v.src} type="video/mp4" />
                  <track kind="captions" src="" label="Indonesia" lang="id" />
                  Browser Anda tidak mendukung pemutaran video.
                </video>
              </div>
              
              <!-- Info Konten -->
              <div class="p-5">
                <h3 class="font-bold text-slate-800 text-lg line-clamp-2 leading-snug tracking-tight min-h-[3.5rem]">
                  {v.name}
                </h3>
              </div>
            </div>
            
            <!-- Metadata Footer Kartu -->
            <div class="px-5 pb-5 mt-auto">
              <div class="pt-4 border-t border-slate-100 flex justify-between items-center text-xs font-medium text-slate-500">
                <!-- Status Badge Lebih Elegan -->
                <span class="flex items-center gap-1.5 bg-green-50 text-green-700 px-2.5 py-1 rounded-full text-[11px] font-semibold">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  Selesai
                </span>
                <span class="text-slate-400">Dipublikasi: {v.date}</span>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
    
  </div>
</section>
