---
const { whatsapp } = Astro.props;

const data = [
  {
    title: "Gabung Grup Whatsapp",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#FFFFFF"><path d="M240-320q-33 0-56.5-23.5T160-400q0-33 23.5-56.5T240-480q33 0 56.5 23.5T320-400q0 33-23.5 56.5T240-320Zm480 0q-33 0-56.5-23.5T640-400q0-33 23.5-56.5T720-480q33 0 56.5 23.5T800-400q0 33-23.5 56.5T720-320Zm-240-40q-42 0-71-29t-29-71q0-42 29-71t71-29q42 0 71 29t29 71q0 42-29 71t-71 29ZM284-120q14-69 68.5-114.5T480-280q73 0 127.5 45.5T676-120H284Zm-204 0q0-66 47-113t113-47q17 0 32 3t29 9q-30 29-50 66.5T224-120H80Zm656 0q-7-44-27-81.5T659-268q14-6 29-9t32-3q66 0 113 47t47 113H736ZM88-480l-48-64 440-336 160 122v-82h120v174l160 122-48 64-392-299L88-480Z"/></svg>`,
    link: "https://chat.whatsapp.com/Bufz5pOsRZsJEAlmZYH0nT",
  },
  {
    title: "Saluran Whatsapp Kami",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#FFFFFF"><path d="M440-280H280q-83 0-141.5-58.5T80-480q0-83 58.5-141.5T280-680h160v80H280q-50 0-85 35t-35 85q0 50 35 85t85 35h160v80ZM320-440v-80h320v80H320Zm200 160v-80h160q50 0 85-35t35-85q0-50-35-85t-85-35H520v-80h160q83 0 141.5 58.5T880-480q0 83-58.5 141.5T680-280H520Z"/></svg>`,
    link: "https://whatsapp.com/channel/0029Vb4TIMyElagsK3Rnjh2L",
  },
];
---

<section id="kontak" aria-labelledby="cta-heading" class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 id="cta-heading" class="text-4xl font-bold text-slate-900 mb-6">
      Siap Meningkatkan Standar Kebersihan Anda?
    </h2>
    <p class="text-lg text-slate-700 mb-10">
      Dapatkan katalog lengkap produk kami atau hubungi tim sales untuk
      penawaran kerja sama B2B dan distribusi.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      {
        data.map((item) => (
          <a
            href={item.link}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition flex items-center justify-center gap-2 shadow-lg shadow-green-200"
          >
            <Fragment set:html={item.icon} />
            {item.title}
          </a>
        ))
      }
      <a
        href={`https://wa.me/legenda`}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition flex items-center justify-center gap-2 shadow-lg shadow-green-200"
      >
        <img
          src="/whtasapp.svg"
          class="h-5 invert brightness-0 filter"
          alt="whatsapp"
        /> Hubungi WhatsApp Kami
      </a>
      <a
        href={`https://wa.me/legenda`}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition flex items-center justify-start gap-2 shadow-lg shadow-green-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="h-5" fill="#FFFFFF"
          ><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
          <path
            d="M448.5 209.9c-44 .1-87-13.6-122.8-39.2l0 178.7c0 33.1-10.1 65.4-29 92.6s-45.6 48-76.6 59.6-64.8 13.5-96.9 5.3-60.9-25.9-82.7-50.8-35.3-56-39-88.9 2.9-66.1 18.6-95.2 40-52.7 69.6-67.7 62.9-20.5 95.7-16l0 89.9c-15-4.7-31.1-4.6-46 .4s-27.9 14.6-37 27.3-14 28.1-13.9 43.9 5.2 31 14.5 43.7 22.4 22.1 37.4 26.9 31.1 4.8 46-.1 28-14.4 37.2-27.1 14.2-28.1 14.2-43.8l0-349.4 88 0c-.1 7.4 .6 14.9 1.9 22.2 3.1 16.3 9.4 31.9 18.7 45.7s21.3 25.6 35.2 34.6c19.9 13.1 43.2 20.1 67 20.1l0 87.4z"
          ></path></svg
        > Tiktok Kami
      </a>
    </div>
  </div>
</section>
