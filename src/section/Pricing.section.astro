---
import "../styles/global.css";
import produk from '../config/data_produk.js';
import Card from "../components/ui/Card.astro";

interface Props {
  whatsapp: string;
}

const { whatsapp } = Astro.props;
---

<section id="produk" aria-labelledby="produk-heading" class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 id="produk-heading" class="text-3xl font-bold text-slate-900 mb-4">
        Koleksi Produk Unggulan
      </h2>
      <p class="text-slate-700 italic">
        "Kualitas legendaris dengan penawaran harga terbaik untuk kebutuhan
        retail maupun skala besar."
      </p>
    </div>

    <!-- Menggunakan elemen list semantik untuk struktur katalog produk -->
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 list-none p-0">
      {
        produk.map((item) => (
          <li>
            <Card title={item.title} image={item.image} desk={item.desc}>
              <a 
                href={`https://wa.me/${whatsapp}?text=saya+tertarik+dengan+produk+${encodeURIComponent(item.title)}+bisa+jelaskan+lebih+detail?`} 
                class="inline-block w-full text-center bg-blue-800 hover:bg-blue-900 text-white font-semibold py-2.5 px-4 rounded-lg transition-colors focus:ring-4 focus:ring-blue-300"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Beli ${item.title} - Dapatkan Harga Khusus lewat WhatsApp`}
              >
                Dapatkan Harga Khusus
              </a>
            </Card>
          </li>
        ))
      }
    </ul>
  </div>
</section>

